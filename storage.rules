rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Notes attachments — authenticated users can read, only mentors/admins can write
    match /notes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Catch-all for other uploads
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
